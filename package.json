{
  "name": "business-system",
  "version": "1.0.0",
  "description": "弗里得沃业务管理系统",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "publish": "onTagOrDraft"
  },
  "keywords": [
    "business",
    "crm",
    "management"
  ],
  "author": "弗里得沃",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "sql.js": "^1.12.0"
  },
  "build": {
    "appId": "com.fwitco.business",
    "productName": "弗里得沃业务系统",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.business",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "xiangcai1123-debug",
        "repo": "business-system"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "database.js",
      "index.html",
      "node_modules/sql.js/dist/sql-wasm.wasm",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ]
  }
}
